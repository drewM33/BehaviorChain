# Dashboard Vite (client) — prefix VITE_
VITE_WORLDCOIN_APP_ID=app_staging_xxxxxxxx
VITE_WORLDCOIN_RP_ID=rp_staging_xxxxxxxx
# Optional: must match an action created in the Developer Portal (default matches Admin “Create agent” flow)
# VITE_WORLDCOIN_GATE_ACTION=register-behaviorchain-agent
# staging | production — use staging with https://simulator.worldcoin.org/
# VITE_WORLDCOIN_IDKIT_ENV=staging

# Dashboard API (Hono on port 3001) — never expose the signing key to the client
# Developer Portal → your app → World ID 4.0 → RP signing key (secret)
WORLDCOIN_RP_SIGNING_KEY=0x
# Same rp_id as VITE_WORLDCOIN_RP_ID (server uses this for POST /api/v4/verify)
WORLDCOIN_RP_ID=rp_staging_xxxxxxxx

# Optional alias some docs use:
# RP_SIGNING_KEY=0x
