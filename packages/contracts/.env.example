# RPC URL — set to mainnet for production deployment
# Base Sepolia: https://sepolia.base.org
# Base Mainnet: https://mainnet.base.org
BEHAVIORCHAIN_RPC_URL=https://mainnet.base.org

# Deployer private key (never commit the real key)
BEHAVIORCHAIN_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Contract addresses (set after deployment)
# Base Sepolia (testnet):
BEHAVIORCHAIN_CONTRACT_ADDRESS_TESTNET=0x8DdD21004CC5EF801b3Fa5017842Fa9Bf62dAed0
# Base Mainnet:
BEHAVIORCHAIN_CONTRACT_ADDRESS=

# BaseScan API key (for contract verification)
BASESCAN_API_KEY=
